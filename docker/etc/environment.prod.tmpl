# Production environment template (copy to /home/deployer/atom/docker/etc/environment on prod VM).
#
# Do not commit real passwords/secrets.

# Elasticsearch
bootstrap.memory_lock=true
cluster.routing.allocation.disk.threshold_enabled=false
discovery.type=single-node
ES_JAVA_OPTS=-Xms640m -Xmx640m
bootstrap.system_call_filter=false

# MySQL
MYSQL_ROOT_PASSWORD=__SET_ME__
MYSQL_DATABASE=atom
MYSQL_USER=atom
MYSQL_PASSWORD=__SET_ME__

# AtoM and AtoM worker
ATOM_DEVELOPMENT_MODE=off
ATOM_ELASTICSEARCH_HOST=elasticsearch
ATOM_MEMCACHED_HOST=memcached
ATOM_GEARMAND_HOST=gearmand
ATOM_MYSQL_DSN=mysql:host=percona;port=3306;dbname=atom;charset=utf8mb4
ATOM_MYSQL_USERNAME=atom
ATOM_MYSQL_PASSWORD=__SET_ME__
NODE_ENV=production

