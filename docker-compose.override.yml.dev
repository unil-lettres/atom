# docker-compose.override.yml.dev
services:

  atom-app:
    build:
      context: .
      dockerfile: ./init/Dockerfile
    volumes:
      - atom_app:/usr/share/nginx/atom
      - ./plugins/arLettresPlugin:/usr/share/nginx/atom/plugins/arLettresPlugin

  atom-nginx:
    image: nginx:1.27-alpine
    depends_on:
      - atom-app
    ports:
      - "127.0.0.1:8080:80"
    volumes:
      - ./init/nginx.dev.conf:/etc/nginx/conf.d/default.conf:ro
      - atom_app:/usr/share/nginx/atom:ro
      - ./plugins/arLettresPlugin:/usr/share/nginx/atom/plugins/arLettresPlugin:ro
    networks: [atom-net]

volumes:
  atom_app:
