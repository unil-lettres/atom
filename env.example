# AtoM version
ATOM_VERSION=latest

# AtoM site info
SITE_TITLE=Access to Memory
SITE_DESCRIPTION=AtoM archival platform
SITE_URL=http://atom.example.org
SITE_TIMEZONE=Europe/Zurich

# Admin account (created at install)
ADMIN_EMAIL=admin@example.com
ADMIN_PASS=admin

# Database connection
DB_HOST=mysql
DB_NAME=atom
DB_USER=atom
DB_PASS=atompass

# Elasticsearch connection
ES_HOST=elasticsearch
ES_PORT=9200

# Gearman settings
GEARMAND_HOST=gearman
GEARMAND_PORT=4730

# Memcached settings
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211

# Dump & uploads config
DB_DUMP_FILE=atom_dump.sql
UPLOADS_HOST_DIR=./watched/uploads
UPLOADS_TAR=uploads_backup.tar.gz
